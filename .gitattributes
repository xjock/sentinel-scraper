# Default: normalize line endings to LF on checkout
* text=auto eol=lf

# Shell scripts must always use LF
*.sh text eol=lf

# Go source files
*.go text eol=lf
go.mod text eol=lf
go.sum text eol=lf

# Build files
Makefile text eol=lf
Dockerfile text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf

# Binary files: do not modify
*.exe binary
*.dll binary
*.zip binary
*.tar.gz binary
*.tif binary
*.jp2 binary
*.png binary
*.jpg binary
